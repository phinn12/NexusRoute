# Core app
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8010
BACKEND_BASE_URL=http://127.0.0.1:8010

# Output and cache
OUTPUT_DIR=./yerelden_output
GRAPH_CACHE_DIR=./graph_cache
LOG_DIR=./logs

# Routing behavior
ORTOOLS_TIME_LIMIT_SECONDS=30
AVERAGE_SPEED_KMH=30
ROAD_NETWORK_TIMEOUT_SECONDS=30
ROAD_NETWORK_MAX_STOPS_PER_CENTER=120
HEURISTIC_TWO_OPT_MAX_STOPS=80

# Google routing
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# GOOGLE_ROUTE_OPTIMIZATION_PARENT=projects/your-project-id
# GOOGLE_ROUTE_OPTIMIZATION_API_KEY=your_google_route_optimization_key
# GOOGLE_ROUTE_OPTIMIZATION_BEARER_TOKEN=your_bearer_token

# Gemini copilot
# GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite

# Optional UI behavior
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
